{
  "compilerOptions": {
    "incremental": true,
    "target": "es2020",
    "module": "ES2020",
    "declaration": true,
    "sourceMap": true,
    "composite": true,
    "strict": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "preserveConstEnums": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": false
  }
}
