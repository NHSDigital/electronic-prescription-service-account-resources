{
  "name": "cdk",
  "version": "0.1.0",
  "scripts": {
    "cdk-synth": "cdk synth  --output ../../cdk.out --quiet --app \"tsx -- bin/${CDK_APP_NAME}.ts\"",
    "cdk-diff": "cdk diff ${CDK_STACK_NAME}  --output ../../cdk.out --app \"tsx -- bin/${CDK_APP_NAME}.ts\"",
    "cdk-prepare-changeset": "cdk deploy ${CDK_STACK_NAME} --change-set-name ${CDK_CHANGE_SET_NAME} --method prepare-change-set --app \"tsx -- bin/${CDK_APP_NAME}.ts\" --ci true --require-approval ${REQUIRE_APPROVAL}",
    "cdk-check-changeset": "tsx scripts/manageDestructiveChanges.ts",
    "cdk-flags": "cdk flags --unstable=flags --app \"tsx -- bin/${CDK_APP_NAME}.ts\"",
    "lint": "eslint  --max-warnings 0 --fix --config ../../eslint.config.mjs ."
  },
  "dependencies": {
    "@nhsdigital/eps-cdk-constructs": "^1.7.0",
    "aws-cdk-lib": "^2.250.0",
    "cdk-nag": "^2.37.55",
    "constructs": "^10.6.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.1118.2",
    "tsx": "^4.21.0"
  }
}
